{
  "installCommand": "cd healthcare-ai-ui && npm install",
  "buildCommand": "cd healthcare-ai-ui && npm run build",
  "outputDirectory": "healthcare-ai-ui/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://medverify-backend.onrender.com/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
